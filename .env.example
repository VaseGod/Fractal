# ──────────────────────────────────────────────
# Fractal — Environment Configuration
# Copy to .env and fill in values before running
# ──────────────────────────────────────────────

# ── vLLM / Inference ──
VLLM_MODEL_PATH=/models/default
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_QUANTIZATION=awq
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_TARGET_DEVICE=xpu

# ── Intel GPU (Arc Pro B70 B-series) ──
ONEAPI_DEVICE_SELECTOR=level_zero:gpu
ZE_AFFINITY_MASK=0
ZE_ENABLE_PCI_ID_DEVICE_ORDER=1
SYCL_CACHE_PERSISTENT=1

# ── LangChain / LangSmith ──
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_your_api_key_here
LANGCHAIN_PROJECT=fractal-production
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ── Browserbase ──
BROWSERBASE_API_KEY=bb_your_api_key_here
BROWSERBASE_PROJECT_ID=your_project_id

# ── Trigger.dev ──
TRIGGER_API_KEY=tr_your_api_key_here
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_PROJECT_ID=fractal-jobs

# ── ChromaDB ──
CHROMA_HOST=chromadb
CHROMA_PORT=8100
CHROMA_COLLECTION=fractal_memory

# ── Bifrost Middleware ──
BIFROST_CONFIG_PATH=/app/config/bifrost.yaml
BIFROST_MTLS_CERT=/certs/server.crt
BIFROST_MTLS_KEY=/certs/server.key

# ── HITL / Approval ──
HITL_TIMEOUT_SECONDS=300
HITL_ESCALATION_EMAIL=admin@fractal.local

# ── ARC-AGI-3 ──
ARC_AGI_API_KEY=arc_your_api_key_here
ARC_AGI_ENDPOINT=https://api.arc-agi.org/v3
